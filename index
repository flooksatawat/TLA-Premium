        function setPlan(plan) { currentPlan = plan; const b10 = document.getElementById('btn10CX'); if(b10) b10.className = `flex-1 gender-btn ${plan==='10CX'?'active-blue':''}`; const b20 = document.getElementById('btn20CX'); if(b20) b20.className = `flex-1 gender-btn ${plan==='20CX'?'active-blue':''}`; calculate(currentMode); }
        function setGender(gender) { currentGender = gender; const bM = document.getElementById('btnMale'); if(bM) bM.className = `flex-1 gender-btn ${gender==='male'?'active':''}`; const bF = document.getElementById('btnFemale'); if(bF) bF.className = `flex-1 gender-btn ${gender==='female'?'active-pink':''}`; calculate(currentMode); }
        function handlePremiumInput(el) { let v = el.value.replace(/,/g, '').split('.')[0]; if (!isNaN(v) && v !== '') { el.value = Number(v).toLocaleString(); calculate('premium'); } }
        function handleSumInput(el) { let v = el.value.replace(/,/g, '').split('.')[0]; if (!isNaN(v) && v !== '') { el.value = Number(v).toLocaleString(); calculate('sum'); } }
        function setQuickSum(val) { const el = document.getElementById('sumInsuredInput'); if(el) { el.value = val.toLocaleString(); calculate('sum'); } }
        function setQuickPremium(val) { const el = document.getElementById('premiumInput'); if(el) { el.value = val.toLocaleString(); calculate('premium'); } }
        
        function getDiscount(sum, plan) { 
            if (sum >= 2000000) return 0.5; 
            return 0; 
        }
        
        function calculate(source) { 
            currentMode = source;
            const ageInput = document.getElementById('ageInput'); 
            const age = parseInt(ageInput ? ageInput.value : 0) || 0; 
            const totalRate = (LIFE_RATES[currentPlan]?.[currentGender]?.[age] || 0) + (CI_RATES[currentPlan]?.[currentGender]?.[age] || 0); 
            if (totalRate <= 0) return null; 
            let fSum = 0, fPrem = 0; 
            if (source === 'sum') { 
                const sumInput = document.getElementById('sumInsuredInput'); 
                fSum = parseFloat(sumInput ? sumInput.value.replace(/,/g, '') : 0) || 0; 
                if (currentGender === 'female' && fSum < 400000) { showCustomError("เพศหญิง ทุนประกันขั้นต่ำ 400,000 บาท"); return null; } 
                if (currentGender === 'male' && fSum < 600000) { showCustomError("เพศชาย ทุนประกันขั้นต่ำ 600,000 บาท"); return null; } 
                fPrem = Math.round((fSum / 1000) * (totalRate - getDiscount(fSum, currentPlan))); 
                const premInput = document.getElementById('premiumInput'); 
                if(premInput) premInput.value = fPrem.toLocaleString(); 
            } else { 
                const premInput = document.getElementById('premiumInput'); 
                fPrem = parseFloat(premInput ? premInput.value.replace(/,/g, '') : 50000) || 0; 
                for (let d_val of [0.5, 0]) { 
                    let s = (fPrem * 1000) / (totalRate - d_val); 
                    if (getDiscount(s + 1, currentPlan) === d_val) { fSum = s; break; } 
                } 
                if (fSum === 0) fSum = (fPrem * 1000) / totalRate; 
                if (currentGender === 'female' && fSum < 400000) { showCustomError("เบี้ยที่ระบุทำให้ทุนประกันต่ำกว่า 400,000 บาท"); return null; } 
                if (currentGender === 'male' && fSum < 600000) { showCustomError("เบี้ยที่ระบุทำให้ทุนประกันต่ำกว่า 600,000 บาท"); return null; } 
                const sumInput = document.getElementById('sumInsuredInput'); 
                if(sumInput) sumInput.value = formatNum(fSum); 
            } 
            
            const dispPrem = document.getElementById('displayPremium');
            const dispDaily = document.getElementById('displayDailyPremium');
            const dailyRow = document.getElementById('dailyPremiumRow');

            if(dispPrem) {
                if (fPrem > 0 && fPrem < 4000) {
                    dispPrem.innerHTML = '<span class="text-[12px] text-red-600 font-bold tracking-tight">เบี้ยประกันรายปี ขั้นต่ำ 4,000 บาท</span>';
                    if(dailyRow) dailyRow.classList.add('hidden');
                } else {
                    dispPrem.innerText = Math.round(fPrem).toLocaleString();
                    if(dailyRow) {
                        dailyRow.classList.remove('hidden');
                        if(dispDaily) {
                            dispDaily.innerText = formatNum(fPrem / 365);
                        }
                    }
                }
            }

            lastCalculationData = { premium: fPrem, sum: fSum, gender: currentGender==='male'?'ชาย':'หญิง', age: age, years: currentPlan==='10CX'?'10':'20' }; 
            refreshAllDisplays(); 
            return lastCalculationData; 
        }
        
        function refreshAllDisplays() { 
            if (!lastCalculationData) return; 
            const p = lastCalculationData.premium; 
            const fyc = Math.round(p * COM_RATES[currentPlan][0]); 
            setText('caseIncomeComm', fyc.toLocaleString() + " บาท"); 
            setText('sumMonthly', Math.round(p * 0.09).toLocaleString()); 
            setText('sum3Month', Math.round(p * 0.27).toLocaleString()); 
            setText('sum6Month', Math.round(p * 0.52).toLocaleString()); 
            let comH = `<h4 class="text-xs font-bold text-amber-900 mb-3 tracking-wide text-center">ประมาณการคอมมิชชันรายปี</h4>`; 
            let totalComAmt = 0; 
            COM_RATES[currentPlan].forEach((r, i) => { 
                const annualAmt = Math.round(p * r); 
                totalComAmt += annualAmt; 
                comH += `<div class="com-item-row"><span class="com-percent-label" style="margin-left: 0; margin-right: 12px; flex: none; width: 45px; text-align: left;">${(r*100).toFixed(1)}%</span><span class="com-year-pill">ปีที่ ${i+1}</span><span class="com-amount-value" style="flex: 1;">${annualAmt.toLocaleString()}</span></div>`; 
            }); 
            const totalPercent = ((totalComAmt / p) * 100).toFixed(1); 
            comH += `<div class="mt-4 pt-3 border-t-2 border-amber-200 flex justify-between items-center"><div class="text-left"><div class="text-lg font-black text-amber-600">${totalPercent}%</div><div class="text-[8px] font-bold text-amber-900 uppercase">Percent รวม</div></div><div class="text-right"><div class="text-xs font-bold text-amber-900">คอมมิชชันรวมตลอดสัญญา</div><div class="text-lg font-black text-amber-600">${totalComAmt.toLocaleString()} บาท</div></div></div>`; 
            document.getElementById('comList').innerHTML = comH; 
            updateMBDisplay(); 
            updateMYBDisplay(); 
            updateNABDisplay(); 
            const caseTotal = Math.round(fyc + (window.currentMBBonus || 0) + (window.currentMYBBonus || 0) + (window.currentNABBonus || 0)); 
            setText('caseIncomeTotal', caseTotal.toLocaleString() + " บาท"); 
            setText('caseIncomePercent', "(" + ((caseTotal / p) * 100).toFixed(1) + "%)"); 
        }
        
        function updateMBDisplay() { 
            if (!lastCalculationData) return; 
            const newFYC = Math.round(lastCalculationData.premium * COM_RATES[currentPlan][0]); 
            const existingFYC = parseFloat(document.getElementById('existingFYCInput')?.value.replace(/,/g, '')) || 0; 
            const totalFYC = newFYC + existingFYC; 
            const tiers = [{min:8000, max: 16000, rate:0.20, id:"mb-tier1"}, {min:16001, max: 32000, rate:0.25, id:"mb-tier2"}, {min:32001, max: 64000, rate:0.30, id:"mb-tier3"}, {min:64001, max: Infinity, rate:0.35, id:"mb-tier4"}]; 
            let curIdx = -1; 
            tiers.forEach((t, i) => { 
                const el = document.getElementById(t.id); 
                if(el) { 
                    el.classList.remove("active"); 
                    if (totalFYC > t.max && i < tiers.length - 1) el.classList.add('hidden'); 
                    else el.classList.remove('hidden'); 
                } 
                if (totalFYC >= t.min) curIdx = i; 
            }); 
            if (curIdx >= 0) { 
                const el = document.getElementById(tiers[curIdx].id); 
                if(el) { el.classList.add("active"); el.classList.remove('hidden'); } 
            } 
            const currentRate = curIdx >= 0 ? tiers[curIdx].rate : 0; 
            const existIdx = tiers.findLastIndex(t => existingFYC >= t.min); 
            const existRate = existIdx >= 0 ? tiers[existIdx].rate : 0; 
            const existingBonus = Math.round(existingFYC * existRate); 
            const totalBonus = Math.round(totalFYC * currentRate); 
            window.currentMBBonus = totalBonus - existingBonus; 
            setText('mbExistingCalc', `${existingBonus.toLocaleString()} บาท`); 
            setText('mbCaseCalc', `${window.currentMBBonus.toLocaleString()} บาท`); 
            setText('mbCalculatedBonus', totalBonus.toLocaleString() + " บาท"); 
            setText('mbFormula', `(${existingFYC.toLocaleString()} + ${newFYC.toLocaleString()} = ${totalFYC.toLocaleString()} x ${currentRate * 100}%)`); 
            setText('mbCaseComm', newFYC.toLocaleString() + " บาท"); 
            const adviceBox = document.getElementById('mbAdvice'); 
            if (adviceBox) { 
                if (curIdx < 3) { 
                    const next = tiers[curIdx + 1]; 
                    adviceBox.classList.remove('success'); 
                    adviceBox.innerHTML = `<i class=\"fas fa-lightbulb text-amber-500 text-lg\"></i><div class=\"flex-1 text-slate-700\"><strong>เพิ่มอีก ${(next.min - totalFYC).toLocaleString()} บาท</strong><br><span>เพื่อรับโบนัสระดับถัดไป ${(next.rate * 100)}%</span></div>`; 
                } else { 
                    adviceBox.classList.add('success'); 
                    adviceBox.innerHTML = `<i class=\"fas fa-trophy text-emerald-500 text-lg\"></i><span class=\"text-emerald-900 font-bold\">ยินดีด้วย! คุณได้รับโบนัสระดับสูงสุด 35% แล้ว</span>`; 
                    if (window.lastMaxBonusFYC_MB !== totalFYC && !document.getElementById('cashMenuContainer').classList.contains('hidden')) { 
                        showCongratsPopup('โบนัสรายเดือน', '35%'); 
                        window.lastMaxBonusFYC_MB = totalFYC; 
                    } 
                } 
            } 
        }

