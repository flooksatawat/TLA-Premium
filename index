<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Convertable Term</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; }
        body { font-family: 'Kanit', sans-serif; background-color: #f8fafc; display: flex; justify-content: center; align-items: flex-start; min-height: 100vh; margin: 0; padding: 20px 10px; color: #1e293b; -webkit-tap-highlight-color: transparent; overflow-x: hidden; }
        .app-container { width: 100%; max-width: 440px; height: fit-content; min-height: auto; background-color: white; display: flex; flex-direction: column; box-shadow: 0 15px 50px rgba(0,0,0,0.1); position: relative; border-radius: 35px; overflow: hidden; margin-bottom: 20px; }
        @media (min-width: 450px) { .app-container { border-radius: 40px; box-shadow: 0 20px 60px rgba(0,0,0,0.15); margin-top: 20px; } }
        .header-card { background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 100%); color: white; padding: clamp(20px, 4vh, 25px) 20px; text-align: center; flex-shrink: 0; }
        .header-card h1 { font-weight: 700; letter-spacing: 0.02em; }
        .content-padding { padding: 15px 20px 0 20px; flex: 1; width: 100%; display: flex; flex-direction: column; }
        .input-box { background-color: #f1f5f9; border: 1.5px solid #e2e8f0; padding: 14px; border-radius: 18px; text-align: center; font-weight: 600; font-size: 1.1rem; width: 100%; color: #0f172a; outline: none; transition: all 0.2s; }
        .input-box:focus { border-color: #1e3a8a; background-color: white; box-shadow: 0 0 0 4px rgba(30, 58, 138, 0.1); }
        .gender-btn { border: 2px solid #e2e8f0; transition: all 0.2s; font-size: 0.95rem; color: #64748b; background-color: white; border-radius: 14px; padding: 12px 5px; font-weight: 600; cursor: pointer; }
        .gender-btn.active-blue { border-color: #1e3a8a; background-color: #eff6ff; color: #1e3a8a; }
        .gender-btn.active { border-color: #10b981; background-color: #ecfdf5; color: #065f46; }
        .gender-btn.active-pink { border-color: #db2777; background-color: #fdf2f8; color: #be185d; }
        .result-card { background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 100%); border-radius: 30px; padding: 25px 15px; color: white; text-align: center; margin: 15px 0; box-shadow: 0 8px 25px -5px rgba(30, 58, 138, 0.3); width: 100%; }
        .premium-input { background: transparent; border: none; border-bottom: 2.5px solid rgba(255, 255, 255, 0.4); text-align: center; font-size: 3.6rem; font-weight: 700; width: 100%; color: white; outline: none; margin-top: 5px; transition: border-color 0.3s; }
        .premium-input:focus { border-bottom-color: white; }
        .menu-btn { width: 100%; padding: 16px; font-size: 0.95rem; font-weight: 600; display: flex; align-items: center; justify-content: center; gap: 10px; transition: all 0.2s; cursor: pointer; border-radius: 20px; border: 1.5px solid #e2e8f0; margin-bottom: 12px; }
        .cash-main-btn { background: linear-gradient(135deg, #f8fafc 0%, #cbd5e1 50%, #94a3b8 100%); color: #0f172a; border: 1px solid #94a3b8; flex-direction: column; padding: 18px; gap: 2px; box-shadow: 0 4px 15px rgba(148, 163, 184, 0.3); margin-top: 10px; }
        .cash-container { background-color: #ffffff; border-radius: 24px; border: 1px solid #cbd5e1; overflow: hidden; margin-top: -6px; margin-bottom: 10px; width: 100%; padding: 10px; }
        .sub-menu-btn { width: 100%; padding: 14px 20px; font-size: 0.9rem; font-weight: 600; display: flex; align-items: center; gap: 12px; transition: all 0.2s ease-in-out; cursor: pointer; border-radius: 16px; margin-bottom: 8px; border: 1.5px solid #e2e8f0; background-color: #ffffff; color: #64748b; }
        .sub-menu-btn:hover { background-color: #f8fafc; color: #334155; }
        .btn-income.is-selected, .btn-income:hover { background-color: #ecfdf5; border-color: #10b981; color: #065f46; }
        .btn-com.is-selected, .btn-com:hover { background-color: #fffbeb; border-color: #f59e0b; color: #92400e; }
        .btn-mb.is-selected, .btn-mb:hover { background-color: #eff6ff; border-color: #3b82f6; color: #1e3a8a; }
        .btn-myb.is-selected, .btn-myb:hover { background-color: #f5f3ff; border-color: #8b5cf6; color: #5b21b6; }
        .btn-nab.is-selected, .btn-nab:hover { background-color: #ecfeff; border-color: #06b6d4; color: #155e75; }
        .info-card { border-radius: 20px; padding: 18px; margin-bottom: 10px; border: 1px solid #e2e8f0; background: #f8fafc; }
        .income-row { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid #e2e8f0; }
        .income-row:last-child { border-bottom: none; }
        .income-label { display: flex; align-items: center; gap: 14px; font-size: 0.9rem; color: #374151; font-weight: 500; }
        .income-label i { width: 22px; text-align: center; font-size: 1.1rem; }
        .income-value { font-weight: 700; font-size: 0.95rem; }
        .tier-table { width: 100%; border-collapse: separate; border-spacing: 0 8px; margin-top: 5px; }
        .tier-table td { padding: 14px; font-size: 0.85rem; background: #ffffff; border: 1px solid #f1f5f9; color: #475569; transition: all 0.2s ease; }
        .tier-table td:first-child { border-radius: 14px 0 0 14px; border-right: none; font-weight: 500; }
        .tier-table td:last-child { border-radius: 0 14px 14px 0; text-align: center; font-weight: 800; border-left: none; color: #1e293b; width: 80px; }
        .active td { background: #ecfdf5 !important; border-color: #10b981 !important; color: #065f46 !important; transform: scale(1.02); box-shadow: 0 4px 12px -3px rgba(16, 185, 129, 0.2); position: relative; z-index: 10; }
        .active td:last-child { background: #d1fae5 !important; color: #047857 !important; }
        .advice-box { background: #fffbeb; border: 1.5px solid #fde68a; border-radius: 18px; padding: 12px 15px; margin-top: 12px; font-size: 13px; color: #92400e; display: flex; align-items: center; gap: 10px; line-height: 1.5; }
        .advice-box i { font-size: 18px; color: #d97706; flex-shrink: 0; }
        .advice-box.success { background: #ecfdf5; border-color: #6ee7b7; color: #065f46; }
        .advice-box.success i { color: #10b981; }
        .com-item-row { display: flex; align-items: center; padding: 12px 0; border-bottom: 1px solid rgba(251, 191, 36, 0.3); font-size: 0.85rem; }
        .com-item-row:last-child { border-bottom: none; }
        .com-year-pill { background: #fef3c7; border: 1.5px solid #fbbf24; color: #92400e; padding: 3px 12px; border-radius: 20px; font-weight: 700; width: 75px; text-align: center; font-size: 0.75rem; }
        .com-percent-label { font-size: 0.8rem; color: #78350f; margin-left: 12px; flex: 1; font-weight: 600; }
        .com-amount-value { font-size: 1rem; font-weight: 700; color: #78350f; text-align: right; }
        .modal-overlay { background-color: rgba(15, 23, 42, 0.85); backdrop-filter: blur(5px); transition: opacity 0.2s ease-out; opacity: 0; pointer-events: none; visibility: hidden; z-index: 100; position: fixed; inset: 0; display: flex; align-items: center; justify-content: center; padding: 1.5rem; }
        .modal-overlay.show { opacity: 1; pointer-events: auto; visibility: visible; }
        .modal-content-card { background-color: white; width: 100%; max-width: 24rem; border-radius: 35px; overflow: hidden; max-height: 90vh; display: flex; flex-direction: column; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.4); }
        .modal-scroll-area { overflow-y: auto; padding: 1.5rem; flex: 1; }
        .company-footer { text-align: center; font-size: 10px; color: #94a3b8; margin-top: 40px; padding-bottom: 25px; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 500; width: 100%; opacity: 0.8; }
        .hidden { display: none; }
        @keyframes pulse-red { 0% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.1); opacity: 0.7; } 100% { transform: scale(1); opacity: 1; } }
        .listening-active { color: #ef4444; animation: pulse-red 1s infinite; }
        .quick-sum-btn { font-size: 10px; font-weight: 700; padding: 8px 2px; border-radius: 12px; background-color: #eff6ff; color: #1e40af; border: 1.5px solid #dbeafe; transition: all 0.2s; cursor: pointer; display: block; width: 100%; text-align: center; }
        .quick-sum-btn:active { transform: scale(0.95); background-color: #dbeafe; }
        .ai-header-btn { width: 100%; padding: 12px 15px; background: white; border-radius: 15px; border: 1px solid #e0e7ff; display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; cursor: pointer; transition: all 0.2s; }
        .ai-header-btn:hover { background: #f5f7ff; }
        .ai-header-btn h4 { font-size: 14px; font-weight: 800; color: #4338ca; text-transform: uppercase; letter-spacing: 0.05em; } 
        .ai-content-box { background: white; padding: 15px; border-radius: 15px; border: 1px solid #f0f4ff; margin-bottom: 12px; font-size: 14px; color: #475569; line-height: 1.6; position: relative; } 
        .ai-refresh-btn { position: absolute; top: 12px; right: 12px; font-size: 16px; color: #6366f1; cursor: pointer; transition: transform 0.3s; padding: 5px; }
        .ai-refresh-btn:active { transform: rotate(180deg); }
    </style>
</head>
<body>
    <div class="app-container">
        <div class="header-card">
            <h1 class="text-2xl font-bold tracking-tight">Convertable Term</h1>
            <p class="text-xs opacity-90 mt-1 font-medium text-center px-4">จองสิทธิ เปลี่ยนแบบประกันได้ แม้ตรวจพบโรคร้ายหรือมีประวัติสุขภาพ</p>
        </div>
        <div class="w-full">
            <div onclick="document.getElementById('insuranceConditions').classList.toggle('hidden')" class="bg-blue-50/80 border-b border-blue-100 p-3.5 cursor-pointer hover:bg-blue-100 transition-colors text-center">
                <h2 class="text-[10px] font-bold text-blue-900 uppercase tracking-[0.2em] flex justify-center items-center gap-2">
                    <i class="fas fa-info-circle text-blue-600"></i>
                    <span>เงื่อนไขการรับประกัน</span>
                    <i class="fas fa-caret-down text-blue-400"></i>
                </h2>
                <div id="insuranceConditions" class="hidden mt-3 grid grid-cols-1 gap-1 text-[11px] text-blue-800/80 font-medium border-t border-blue-100 pt-2 px-6 text-left space-y-1 pb-1">
                    <p>• อายุที่รับประกัน: 20 - 60 ปี</p>
                    <p>• ทุนประกันขั้นต่ำ</p>
                    <p class="pl-4 font-semibold text-blue-900/70">• เพศหญิง 400,000 บาท</p>
                    <p class="pl-4 font-semibold text-blue-900/70">• เพศชาย 600,000 บาท</p>
                    <p class="mt-2 text-blue-900 font-bold">• สามารถเปลี่ยนแบบประกันได้ ในปีที่ 4</p>
                    <p class="text-red-700 font-bold mt-1 text-[10px] bg-yellow-100 px-2 py-0.5 rounded inline-block">• เปลี่ยนแบบประกันในปีที่ 4 ยกเว้น ประกันโรคร้าย ประกันสุขภาพ</p>
                </div>
            </div>
        </div>
        <div class="content-padding">
            <div class="bg-slate-50 p-4 rounded-2xl mb-4 border border-slate-100 shadow-sm">
                <div class="flex gap-2">
                    <input type="text" id="textCommand" class="input-box text-[clamp(8px,2.9vw,14px)] text-left px-1.5 min-[375px]:px-3 sm:px-5 flex-1 tracking-tighter sm:tracking-tight" placeholder="ช/ญ + อายุ + ทุนประกัน" onkeypress="handleEnter(event)" oninput="adjustInputFontSize(this)">
                    <button id="voiceBtn" onclick="startVoiceRecognition()" class="bg-white border border-slate-200 text-slate-500 w-12 rounded-2xl flex items-center justify-center active:scale-95 transition-all shadow-sm shrink-0">
                        <i id="voiceIcon" class="fas fa-microphone"></i>
                    </button>
                    <button onclick="processTextCommand()" class="bg-blue-900 text-white w-12 rounded-2xl flex items-center justify-center active:scale-95 transition-all shadow-sm shrink-0">
                        <i class="fas fa-paper-plane"></i>
                    </button>
                </div>
            </div>
            <div class="flex flex-col items-center w-full">
                <!-- เมนูคำนวณเบี้ยประกันด้วยตนเอง -->
                <button onclick="toggleSettings()" class="menu-btn bg-blue-100 text-blue-900 border-blue-200 shadow-sm hover:bg-blue-200 transition-colors h-[90px]">
                    <i class="fas fa-sliders-h text-2xl"></i>
                    <span class="text-[1.05rem] whitespace-nowrap">คำนวณเบี้ยประกันด้วยตนเอง</span>
                </button>
                
                <div id="manualInputs" class="hidden space-y-4 w-full pt-2 pb-5 border-b border-slate-200">
                    <div class="grid grid-cols-2 gap-3 text-center">
                        <div>
                            <p class="text-slate-500 text-[10px] font-bold uppercase mb-1.5 tracking-wide">เพศ</p>
                            <div class="flex gap-2">
                                <button onclick="setGender('male')" id="btnMale" class="flex-1 gender-btn active">ชาย</button>
                                <button onclick="setGender('female')" id="btnFemale" class="flex-1 gender-btn">หญิง</button>
                            </div>
                        </div>
                        <div>
                            <p class="text-slate-500 text-[10px] font-bold uppercase mb-1.5 tracking-wide">อายุ (ปี)</p>
                            <input type="number" id="ageInput" value="20" min="20" max="60" class="input-box" oninput="calculate(currentMode)">
                        </div>
                    </div>
                    <!-- ทุนประกัน -->
                    <div>
                        <p class="text-slate-500 text-[10px] font-bold uppercase mb-1.5 text-center tracking-wide">ทุนประกัน (บาท)</p>
                        <div class="grid grid-cols-5 gap-1.5 mb-2">
                            <button onclick="setQuickSum(400000)" class="quick-sum-btn">4 แสน</button>
                            <button onclick="setQuickSum(600000)" class="quick-sum-btn">6 แสน</button>
                            <button onclick="setQuickSum(1000000)" class="quick-sum-btn">1 ล้าน</button>
                            <button onclick="setQuickSum(3000000)" class="quick-sum-btn">3 ล้าน</button>
                            <button onclick="setQuickSum(5000000)" class="quick-sum-btn">5 ล้าน</button>
                        </div>
                        <input type="text" id="sumInsuredInput" value="1,000,000" class="input-box" oninput="handleSumInput(this)">
                        
                        <!-- การแสดงผลเบี้ยประกันแบบ Card Box -->
                        <div class="mt-4 bg-blue-50 border border-blue-100 rounded-2xl p-4 shadow-sm space-y-3">
                            <div class="flex justify-between items-center">
                                <span class="text-[11px] font-bold text-blue-800 uppercase tracking-wide">เบี้ยประกัน (บาท/ปี)</span>
                                <span id="displayPremium" class="text-xl font-black text-blue-900">0</span>
                            </div>
                            <div id="dailyPremiumRow" class="flex justify-between items-center pt-2 border-t border-blue-200/50">
                                <span class="text-[11px] font-bold text-blue-600 uppercase tracking-wide">เฉลี่ยเพียง (บาท/วัน)</span>
                                <span id="displayDailyPremium" class="text-lg font-bold text-blue-700">0</span>
                            </div>
                        </div>
                    </div>
                    <button onclick="manualTriggerPopup()" class="w-full bg-blue-900 text-white py-4 rounded-2xl font-bold shadow-lg active:scale-95 transition-all text-sm uppercase mt-2">ดูสรุปการคำนวณ & คัดลอก</button>

                    <button onclick="toggleInstallmentDetails()" class="w-full bg-slate-50 border border-slate-200 py-3 rounded-2xl text-[11px] font-bold text-slate-600 flex items-center justify-center gap-2 mt-2 active:bg-slate-100 transition-colors">
                        <i class="fas fa-credit-card text-blue-800"></i> ตัวเลือกการชำระเงิน
                    </button>
                    <div id="installmentDetails" class="hidden mb-1 mt-2">
                        <div class="flex justify-between items-center bg-blue-50/50 border border-blue-100 p-2.5 rounded-2xl gap-2">
                            <button onclick="copyInstallment('monthly')" class="text-center flex-1 bg-white border border-blue-100 p-2 rounded-xl active:scale-95 transition-transform shadow-sm hover:bg-blue-50 cursor-pointer">
                                <p class="text-[9px] text-slate-400 font-bold uppercase mb-1">รายเดือน</p>
                                <p id="sumMonthly" class="text-[12px] font-bold text-blue-900">0</p>
                            </button>
                            <button onclick="copyInstallment('3month')" class="text-center flex-1 bg-white border border-blue-100 p-2 rounded-xl active:scale-95 transition-transform shadow-sm hover:bg-blue-50 cursor-pointer">
                                <p class="text-[9px] text-slate-400 font-bold uppercase mb-1">3 เดือน</p>
                                <p id="sum3Month" class="text-[12px] font-bold text-blue-900">0</p>
                            </button>
                            <button onclick="copyInstallment('6month')" class="text-center flex-1 bg-white border border-blue-100 p-2 rounded-xl active:scale-95 transition-transform shadow-sm hover:bg-blue-50 cursor-pointer">
                                <p class="text-[9px] text-slate-400 font-bold uppercase mb-1">6 เดือน</p>
                                <p id="sum6Month" class="text-[12px] font-bold text-blue-900">0</p>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- เมนู: ที่ปรึกษาการขาย อัจฉริยะ -->
                <button onclick="toggleAIAdvisor()" class="menu-btn bg-indigo-50 text-indigo-900 border-indigo-100 shadow-sm hover:bg-indigo-100 transition-colors h-[90px] !px-3">
                    <i class="fas fa-robot text-indigo-600 text-2xl shrink-0"></i>
                    <span class="text-[clamp(13px,4vw,1.05rem)] whitespace-nowrap">ที่ปรึกษาการขาย อัจฉริยะ</span>
                </button>

                <div id="aiAdvisorContainer" class="hidden cash-container border-indigo-100 bg-indigo-50/10 p-4">
                    <div class="ai-header-btn" onclick="toggleAISection('aiIdea')">
                        <h4><i class="fas fa-lightbulb mr-2"></i> ไอเดียการขาย</h4>
                        <i class="fas fa-plus text-[8px] text-indigo-300"></i>
                    </div>
                    <div id="aiIdea" class="block ai-content-box"><i onclick="updateAIIdeas(true)" class="fas fa-sync-alt ai-refresh-btn"></i><p id="aiIdeaText">กำลังวิเคราะห์ข้อมูล...</p></div>
                </div>

                <!-- ระบบ CASH Menu -->
                <button onclick="toggleCashMenu()" class="menu-btn cash-main-btn shadow-md h-[90px]">
                    <div class="flex items-center justify-center gap-4">
                        <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" fill="none"><rect x="3" y="14" width="4" height="6" rx="1" fill="#94a3b8" /><rect x="10" y="10" width="4" height="10" rx="1" fill="#64748b" /><rect x="17" y="6" width="4" height="14" rx="1" fill="#1e3a8a" /></svg>
                        <span class="text-xl font-bold tracking-[0.25em] text-slate-900 uppercase">CASH</span>
                    </div>
                    <span class="text-[13px] font-bold tracking-widest mt-1 text-blue-900 text-center">CHUBB Agency Success Howto</span>
                </button>

                <div id="cashMenuContainer" class="hidden cash-container">
                    <button onclick="toggleSection('caseIncomeInputs')" class="sub-menu-btn btn-income"><i class="fas fa-wallet"></i><span>รายได้จากเคสนี้</span></button>
                    <div id="caseIncomeInputs" class="hidden info-card border-emerald-200 bg-emerald-50/30">
                        <div class="space-y-1">
                            <div class="income-row"><div class="income-label"><i class="fas fa-coins text-emerald-600"></i><span class="text-emerald-900">คอมมิชชันปีที่ 1</span></div><span id="caseIncomeComm" class="income-value text-emerald-700">0 บาท</span></div>
                            <div class="income-row"><div class="income-label"><i class="fas fa-calendar-alt text-blue-500"></i><span class="text-emerald-900">โบนัสรายเดือน (MB)</span></div><span id="caseIncomeBonus" class="income-value text-blue-600">0 บาท</span></div>
                            <div class="income-row border-none"><div class="income-label"><i class="fas fa-award text-violet-500"></i><span class="text-emerald-900">โบนัสครึ่งปี (MYB)</span></div><span id="caseIncomeMYBonus" class="income-value text-violet-600">0 บาท</span></div>
                            <div class="bg-gradient-to-r from-emerald-500 to-teal-600 p-5 rounded-2xl flex justify-between items-center mt-3 shadow-md">
                                <span class="text-xs font-bold text-white uppercase tracking-widest">รายได้สุทธิ <span id="caseIncomePercent" class="font-normal opacity-90"></span></span>
                                <span id="caseIncomeTotal" class="text-[20px] font-black text-white">0 บาท</span>
                            </div>
                        </div>
                    </div>
                    <button onclick="toggleSection('comInputs')" class="sub-menu-btn btn-com"><i class="fas fa-hand-holding-usd"></i><span>รายได้ที่ได้รับ</span></button>
                    <div id="comInputs" class="hidden info-card border-amber-200 bg-amber-50/30"><div id="comList"></div></div>
                    <button onclick="toggleSection('mbInputs')" class="sub-menu-btn btn-mb"><i class="fas fa-gift"></i><span>โบนัสรายเดือน (MB)</span></button>
                    <div id="mbInputs" class="hidden info-card border-blue-200 bg-blue-50/30">
                        <p class="text-[10px] font-bold text-blue-900 uppercase mb-3 text-center tracking-wide">ระบุยอดสะสมอื่นในเดือนนี้ (บาท)</p>
