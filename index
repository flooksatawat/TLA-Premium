                    if (window.lastMaxBonusFYC_MYB !== totalFYC && !document.getElementById('cashMenuContainer').classList.contains('hidden')) { 
                        showCongratsPopup('โบนัสครึ่งปี', '35%'); 
                        window.lastMaxBonusFYC_MYB = totalFYC; 
                    } 
                } 
            } 
        }

        function updateNABDisplay() { 
            if (!lastCalculationData) return; 
            const fycFromCase = Math.round(lastCalculationData.premium * COM_RATES[currentPlan][0]); 
            const existingFYC = parseFloat(document.getElementById('existingNABFYC')?.value.replace(/,/g, '')) || 0; 
            const existingCases = parseInt(document.getElementById('existingNABCases')?.value) || 0; 
            const phase = document.getElementById('nabPhaseSelect')?.value || 'p1'; 
            const totalFYC = fycFromCase + existingFYC; 
            const totalCases = 1 + existingCases; 
            let tiers = phase === 'p1' ? [{ minFYC: 20000, minCases: 3, bonus: 6000, label: "≥ 20,000 และ 3 ราย" },{ minFYC: 50000, minCases: 5, bonus: 15000, label: "≥ 50,000 และ 5 ราย" }] : [{ minFYC: 40000, minCases: 5, bonus: 10000, label: "≥ 40,000 และ 5 ราย" },{ minFYC: 100000, minCases: 10, bonus: 25000, label: "≥ 100,000 และ 10 ราย" }]; 
            let nabBonus = 0; 
            let currentTierIdx = -1; 
            let tierHtml = ''; 
            tiers.forEach((t, i) => { 
                const fycPassed = totalFYC >= t.minFYC; 
                const casesPassed = totalCases >= t.minCases; 
                const isActive = fycPassed && casesPassed; 
                if (isActive) { nabBonus = t.bonus; currentTierIdx = i; } 
                const fycIcon = fycPassed ? '<i class=\"fas fa-check-circle text-emerald-500\"></i>' : '<i class=\"far fa-circle text-slate-300\"></i>'; 
                const casesIcon = casesPassed ? '<i class=\"fas fa-check-circle text-emerald-500\"></i>' : '<i class=\"far fa-circle text-slate-300\"></i>'; 
                tierHtml += `<tr class=\"${isActive ? 'active' : ''}\"><td class=\"text-left py-3\"><div class=\"font-bold mb-1\">${t.label}</div><div class=\"text-[11px] flex flex-col gap-1\"><span>${fycIcon} FYC: ${totalFYC.toLocaleString()} / ${t.minFYC.toLocaleString()}</span><span>${casesIcon} ราย: ${totalCases} / ${t.minCases}</span></div></td><td class=\"text-right font-black\">${t.bonus.toLocaleString()}</td></tr>`; 
            }); 
            document.getElementById('nabTierBody').innerHTML = tierHtml; 
            window.currentNABBonus = nabBonus; 
            setText('nabCalculatedBonus', nabBonus.toLocaleString() + " บาท"); 
            setText('nabCaseComm', fycFromCase.toLocaleString() + " บาท"); 
            const adviceBox = document.getElementById('nabAdvice'); 
            if (adviceBox) { 
                if (currentTierIdx < tiers.length - 1) { 
                    const nextTier = tiers[currentTierIdx + 1]; 
                    const fycNeed = Math.max(0, nextTier.minFYC - totalFYC); 
                    const casesNeed = Math.max(0, nextTier.minCases - totalCases); 
                    let adviceText = "<strong>เพิ่มอีก "; 
                    if (fycNeed > 0) adviceText += `${fycNeed.toLocaleString()} FYC `; 
                    if (fycNeed > 0 && casesNeed > 0) adviceText += "และ "; 
                    if (casesNeed > 0) adviceText += `${casesNeed} ราย`; 
                    adviceText += `</strong><br><span>เพื่อรับโบนัส ${nextTier.bonus.toLocaleString()} บาท</span>`; 
                    adviceBox.classList.remove('success'); 
                    adviceBox.innerHTML = `<i class=\"fas fa-lightbulb text-cyan-500 text-lg\"></i><div class=\"flex-1 text-cyan-900\">${adviceText}</div>`; 
                } else { 
                    adviceBox.classList.add('success'); 
                    adviceBox.innerHTML = `<i class=\"fas fa-trophy text-emerald-500 text-lg\"></i><span class=\"text-emerald-900 font-bold\">ยินดีด้วย! คุณได้รับโบนัสสูงสุด ${nabBonus.toLocaleString()} บาท แล้ว</span>`; 
                    if (window.lastMaxNABBonus !== nabBonus && nabBonus > 0 && !document.getElementById('cashMenuContainer').classList.contains('hidden')) { 
                        showCongratsPopup('โบนัสตัวแทนใหม่ (NAB)', nabBonus.toLocaleString() + ' บาท'); 
                        window.lastMaxNABBonus = nabBonus; 
                    } 
                } 
            } 
        }

        function closeModal() { document.getElementById('resultModal').classList.remove('show'); }
        function manualTriggerPopup() { openModal(calculate('sum')); }
        function openModal(d) { 
            if(!d) return; 
            setText('modalGender', d.gender); 
            setText('modalAge', d.age + " ปี"); 
            setText('modalYears', d.years + " ปี"); 
            setText('modalPremium', Math.round(d.premium).toLocaleString() + " บาท"); 
            setText('modalSum', formatNum(d.sum) + " บาท"); 
            document.getElementById('resultModal').classList.add('show'); 
        }

        function adjustInputFontSize(el) { 
            el.style.fontSize = '14px'; 
            let currentSize = 14; 
            while (el.scrollWidth > el.clientWidth && currentSize > 9) { 
                currentSize -= 0.5; 
                el.style.fontSize = currentSize + 'px'; 
            } 
        }

        function processTextCommand() { 
            const textRaw = document.getElementById('textCommand').value; 
            if(!textRaw) return; 
            let t = textRaw.toLowerCase().replace(/,/g, ''); 
            let gender = currentGender; 
            if(t.match(/หญิง|ผู้หญิง|สาว/)) gender = 'female'; 
            else if(t.match(/ชาย|ผู้ชาย|หนุ่ม/)) gender = 'male'; 
            let plan = currentPlan; 
            if(t.match(/10\s*cx|10\s*ปี|แผน\s*10/)) plan = '10CX'; 
            else if(t.match(/20\s*cx|20\s*ปี|แผน\s*20/)) plan = '20CX'; 
            let mode = 'premium'; 
            if(t.match(/ทุน|คุ้มครอง/)) mode = 'sum'; 
            let age = -1; let amount = -1; 
            const mults = { 'ล้าน': 1000000, 'แสน': 100000, 'หมื่น': 10000, 'พัน': 1000 }; 
            const regex = /(\d+(?:\.\d+)?)\s*(ล้าน|แสน|หมื่น|พัน)?/g; 
            let match; 
            while ((match = regex.exec(t)) !== null) { 
                let val = parseFloat(match[1]); 
                let m = match[2]; 
                if (m && mults[m]) val *= mults[m]; 
                let contextStr = t.substring(Math.max(0, match.index - 5), Math.min(t.length, regex.lastIndex + 5)); 
                let isPlanIdentifier = (val === 10 || val === 20) && contextStr.match(/cx|ปี|แผน/); 
                if (val >= 1000 || m) { 
                    if (amount === -1) amount = val; 
                } else if (val >= 20 && val <= 60 && age === -1 && !isPlanIdentifier) { 
                    age = val; 
                } 
            } 
            let ageMatch = t.match(/อายุ\s*(\d+)/); 
            if (ageMatch && parseInt(ageMatch[1]) >= 20 && parseInt(ageMatch[1]) <= 60) age = parseInt(ageMatch[1]); 
            if (age !== -1) document.getElementById('ageInput').value = age; 
            if (amount !== -1) { 
                if (mode === 'sum') document.getElementById('sumInsuredInput').value = formatNum(amount); 
                else { const premInput = document.getElementById('premiumInput'); if(premInput) premInput.value = amount.toLocaleString(); } 
            } 
            currentGender = gender; 
            const bM = document.getElementById('btnMale'); if(bM) bM.className = `flex-1 gender-btn ${gender==='male'?'active':''}`; 
            const bF = document.getElementById('btnFemale'); if(bF) bF.className = `flex-1 gender-btn ${gender==='female'?'active-pink':''}`; 
            currentPlan = plan; 
            const b10 = document.getElementById('btn10CX'); if(b10) b10.className = `flex-1 gender-btn ${plan==='10CX'?'active-blue':''}`; 
            const b20 = document.getElementById('btn20CX'); if(b20) b20.className = `flex-1 gender-btn ${plan==='20CX'?'active-blue':''}`; 
            openModal(calculate(mode)); 
            document.getElementById('textCommand').value = ""; 
        }

        function handleEnter(e) { if (e.key === 'Enter') processTextCommand(); }

        function copyToClipboard(text, msg) { 
            const el = document.createElement('textarea'); 
            el.value = text; 
            document.body.appendChild(el); 
            el.select(); 
            document.execCommand('copy'); 
            document.body.removeChild(el); 
            const toast = document.createElement('div'); 
            toast.className = "fixed bottom-10 left-1/2 -translate-x-1/2 bg-blue-900 text-white px-6 py-3 rounded-full text-xs font-bold z-[200] shadow-lg transition-opacity duration-300"; 
            toast.innerText = msg; 
            document.body.appendChild(toast); 
            setTimeout(() => { toast.style.opacity = "0"; setTimeout(() => toast.remove(), 300); }, 2000); 
        }

        function copyInstallment(type) { 
            if (!lastCalculationData) return; 
            const d = lastCalculationData; 
            const p = d.premium; 
            let amt = 0, label = '', minLimit = 0; 
            if(type === 'monthly') { amt = Math.round(p * 0.09); label = 'รายเดือน'; minLimit = 500; } 
            if(type === '3month') { amt = Math.round(p * 0.27); label = 'ราย 3 เดือน'; minLimit = 2500; } 
            if(type === '6month') { amt = Math.round(p * 0.52); label = 'ราย 6 เดือน'; minLimit = 2500; } 

            if (amt < minLimit) {
                showCustomError(`ยอดชำระ${label} ต้องไม่ต่ำกว่า ${minLimit.toLocaleString()} บาท`);
                return;
            }

            const sumStr = formatNum(d.sum); 
            const dailyAvg = formatNum(d.premium / 365);
            let text = `เพศ: ${d.gender}\nอายุ: ${d.age} ปี\nเบี้ยประกัน: ${amt.toLocaleString()} บาท\n(เฉลี่ย ${dailyAvg} บาท/วัน)\nทุนประกัน ${sumStr} บาท\n\n--------------------------\nสามารถเปลี่ยนแบบประกันได้\nตั้งแต่ปีที่ 4 เป็นต้นไป ยกเว้น !\n- ประกันสุขภาพ\n- ประกันโรคร้ายแรง\n--------------------------`; 
            copyToClipboard(text, `คัดลอกยอดชำระ${label}เรียบร้อย`); 
        }

        function handleCopyAndClose() { 
            if (lastCalculationData) { 
                const d = lastCalculationData; 
                const sumStr = formatNum(d.sum); 
                const dailyAvg = formatNum(d.premium / 365);
                let text = `เพศ: ${d.gender}\nอายุ: ${d.age} ปี\nเบี้ยประกัน: ${Math.round(d.premium).toLocaleString()} บาท\n(เฉลี่ย ${dailyAvg} บาท/วัน)\nทุนประกัน ${sumStr} บาท\n\n--------------------------\nสามารถเปลี่ยนแบบประกันได้\nตั้งแต่ปีที่ 4 เป็นต้นไป ยกเว้น !\n- ประกันสุขภาพ\n- ประกันโรคร้ายแรง\n--------------------------`; 
                copyToClipboard(text, "คัดลอกเรียบร้อยแล้ว"); 
            } 
            closeModal(); 
        }

        function startVoiceRecognition() { 
            const SpeechRecognition = window.webkitSpeechRecognition || window.SpeechRecognition; 
            if (!SpeechRecognition) return; 
            const recognition = new SpeechRecognition(); 
            recognition.lang = 'th-TH'; 
            recognition.onstart = () => { document.getElementById('voiceIcon').className = "fas fa-microphone listening-active"; }; 
            recognition.onspeechend = () => { recognition.stop(); document.getElementById('voiceIcon').className = "fas fa-microphone"; }; 
            recognition.onresult = (event) => { document.getElementById('textCommand').value = event.results[0][0].transcript; processTextCommand(); }; 
            recognition.start(); 
        }

        function handleNABFYCInput(el) { let v = el.value.replace(/,/g, ''); if (!isNaN(v) && v !== '') el.value = Number(v).toLocaleString(); updateNABDisplay(); }
        function handleMBInput(el) { let v = el.value.replace(/,/g, ''); if (!isNaN(v) && v !== '') el.value = Number(v).toLocaleString(); updateMBDisplay(); refreshAllDisplays(); }
        function handleMYBInput(el) { let v = el.value.replace(/,/g, ''); if (!isNaN(v) && v !== '') el.value = Number(v).toLocaleString(); updateMYBDisplay(); refreshAllDisplays(); }
        
        function updateAIIdeas(isRefresh = false) { 
            const age = parseInt(document.getElementById('ageInput').value) || 0; 
            const pool = (age >= 20 && age <= 60) ? aiPool.ideas_adult : aiPool.ideas_child; 
            const singleIdea = pool[Math.floor(Math.random() * pool.length)];
            document.getElementById('aiIdeaText').innerHTML = singleIdea; 
        }
        function updateAIAdvisorContent() { updateAIIdeas(); }

        function showDefinition(title, desc) { 
            document.getElementById('defTitle').innerText = title; 
            document.getElementById('defDescription').innerText = desc; 
            const modal = document.getElementById('definitionModal'); 
            modal.classList.remove('opacity-0', 'pointer-events-none'); 
            const content = document.getElementById('defModalContent'); 
            content.classList.remove('scale-95'); 
            content.classList.add('scale-100'); 
        }
        function closeDefinition() { 
            const modal = document.getElementById('definitionModal'); 
            modal.classList.add('opacity-0', 'pointer-events-none'); 
            const content = document.getElementById('defModalContent'); 
            content.classList.remove('scale-100'); 
            content.classList.add('scale-95'); 
        }

        window.onload = () => { calculate('sum'); };
    </script>
